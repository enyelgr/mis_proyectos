<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="horarios_clan_jiu_jitsu.CalendarCommonPopover.body" t-inherit="web.CalendarCommonPopover.body" t-inherit-mode="extension">
        <xpath expr="//ul[1]" position="before">
            <t t-if="props.model.resModel == 'gym.horario'">
                <div class="clan_popover_profile_header">
                    <div class="clan_popover_avatar_wrapper">
                        <t t-if="props.record.rawRecord.instructor_id">
                            <img t-attf-src="/web/image/gym.instructor/{{props.record.rawRecord.instructor_id[0]}}/image" class="clan_popover_avatar_img"/>
                        </t>
                        <t t-else="">
                            <div class="clan_popover_avatar_placeholder">
                                <i class="fa fa-user"/>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
        </xpath>
        
        <!-- Override the time line for gym.horario -->
        <xpath expr="//li[i[contains(@class, 'fa-clock-o')]]" position="replace">
            <li t-if="!props.record.isAllDay" class="list-group-item border-0 pt-0 pb-1">
                <i class="fa fa-clock-o me-2" title="Time"/>
                <t t-if="props.model.resModel == 'gym.horario'">
                    <span t-esc="props.record.rawRecord.hora_inicio_str"/> - <span t-esc="props.record.rawRecord.hora_fin_str"/>
                    (<t t-esc="props.record.rawRecord.duration"/> horas)
                </t>
                <t t-else="">
                    <t t-esc="props.record.start.toFormat('T')"/> - <t t-esc="props.record.end.toFormat('T')"/>
                </t>
            </li>
        </xpath>
    </t>
</templates>
