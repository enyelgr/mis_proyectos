<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Tickets de Soporte - Formulario -->
        <record id="view_support_ticket_form" model="ir.ui.view">
            <field name="name">bh360.support.ticket.form</field>
            <field name="model">bh360.support.ticket</field>
            <field name="arch" type="xml">
                <form string="Ticket de Soporte">
                    <header>
                        <button name="action_start_progress" string="Iniciar" type="object" class="btn-primary" invisible="state != 'new'"/>
                        <button name="action_resolve" string="Resolver" type="object" class="btn-success" invisible="state != 'in_progress'"/>
                        <button name="action_close" string="Cerrar" type="object" class="btn-secondary" invisible="state != 'resolved'"/>
                        <field name="state" widget="statusbar" statusbar_visible="new,in_progress,resolved,closed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="subject"/>
                                <field name="partner_id"/>
                                <field name="category_id"/>
                                <field name="priority"/>
                            </group>
                            <group>
                                <field name="assigned_to"/>
                                <field name="opening_date"/>
                                <field name="deadline_date"/>
                                <field name="closing_date"/>
                            </group>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="satisfaction_rating" widget="radio"/>
                            <field name="satisfaction_comment"/>
                        </group>
                        <field name="company_id" invisible="1"/>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tickets de Soporte - Lista -->
        <record id="view_support_ticket_list" model="ir.ui.view">
            <field name="name">bh360.support.ticket.list</field>
            <field name="model">bh360.support.ticket</field>
            <field name="arch" type="xml">
                <list string="Tickets de Soporte">
                    <field name="name"/>
                    <field name="subject"/>
                    <field name="partner_id"/>
                    <field name="priority"/>
                    <field name="state"/>
                    <field name="deadline_date"/>
                </list>
            </field>
        </record>

        <!-- Acción Tickets -->
        <record id="action_support_ticket" model="ir.actions.act_window">
            <field name="name">Tickets de Soporte</field>
            <field name="res_model">bh360.support.ticket</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
