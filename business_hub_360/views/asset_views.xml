<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Activos Fijos - Formulario -->
        <record id="view_fixed_asset_form" model="ir.ui.view">
            <field name="name">bh360.fixed.asset.form</field>
            <field name="model">bh360.fixed.asset</field>
            <field name="arch" type="xml">
                <form string="Activo Fijo">
                    <header>
                        <button name="action_activate" string="Activar" type="object" class="btn-primary" invisible="status != 'draft'"/>
                        <button name="action_maintenance" string="En Mantenimiento" type="object" class="btn-warning" invisible="status != 'active'"/>
                        <button name="action_dispose" string="Dar de Baja" type="object" class="btn-danger" invisible="status not in ['active', 'inactive']"/>
                        <field name="status" widget="statusbar" statusbar_visible="draft,active,maintenance,disposed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="asset_code" readonly="1"/>
                                <field name="category_id"/>
                                <field name="asset_type"/>
                                <field name="barcode"/>
                            </group>
                            <group>
                                <field name="purchase_value"/>
                                <field name="currency_id"/>
                                <field name="purchase_date"/>
                                <field name="warranty_date"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="current_value"/>
                                <field name="accumulated_depreciation"/>
                            </group>
                            <group>
                                <field name="supplier_id"/>
                                <field name="invoice_number"/>
                                <field name="location_id"/>
                                <field name="responsible_id"/>
                            </group>
                        </group>
                        <group>
                            <field name="notes"/>
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </group>
                        <field name="company_id" invisible="1"/>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Activos Fijos - Lista -->
        <record id="view_fixed_asset_list" model="ir.ui.view">
            <field name="name">bh360.fixed.asset.list</field>
            <field name="model">bh360.fixed.asset</field>
            <field name="arch" type="xml">
                <list string="Activos Fijos">
                    <field name="asset_code"/>
                    <field name="name"/>
                    <field name="asset_type"/>
                    <field name="purchase_value"/>
                    <field name="purchase_date"/>
                    <field name="responsible_id"/>
                    <field name="status"/>
                </list>
            </field>
        </record>

        <!-- Acción Activos Fijos -->
        <record id="action_fixed_asset" model="ir.actions.act_window">
            <field name="name">Activos Fijos</field>
            <field name="res_model">bh360.fixed.asset</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
