        <record id="seq_bh360_expense_claim" model="ir.sequence">
            <field name="name">Business Hub - Gastos</field>
            <field name="code">bh360.expense.claim</field>
            <field name="prefix">EXP/</field>
            <field name="padding">6</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Secuencia: Tickets de Soporte -->
        <record id="seq_bh360_support_ticket" model="ir.sequence">
            <field name="name">Business Hub - Tickets</field>
            <field name="code">bh360.support.ticket</field>
            <field name="prefix">TKT/</field>
            <field name="padding">6</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
