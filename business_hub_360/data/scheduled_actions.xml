<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <!-- Acción Programada: Verificar Alertas de Inventario -->
        <record id="ir_cron_check_inventory_alerts" model="ir.cron">
            <field name="name">Business Hub: Verificar Stock</field>
            <field name="model_id" ref="model_bh360_inventory_alert"/>
            <field name="state">code</field>
            <field name="code">model._check_stock_levels()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active">True</field>
        </record>

        <!-- Acción Programada: Verificar Documentos Vencidos -->
        <record id="ir_cron_check_document_expiry" model="ir.cron">
            <field name="name">Business Hub: Verificar Documentos Vencidos</field>
            <field name="model_id" ref="model_bh360_document"/>
            <field name="state">code</field>
            <field name="code">model._check_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active">True</field>
        </record>

        <!-- Acción Programada: Verificar Garantías de Activos -->
        <record id="ir_cron_check_asset_warranty" model="ir.cron">
            <field name="name">Business Hub: Verificar Garantías</field>
            <field name="model_id" ref="model_bh360_fixed_asset"/>
            <field name="state">code</field>
            <field name="code">model._check_warranty_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active">True</field>
        </record>

        <!-- Acción Programada: Verificar SLA de Tickets -->
        <record id="ir_cron_check_sla_breach" model="ir.cron">
            <field name="name">Business Hub: Verificar SLA Tickets</field>
            <field name="model_id" ref="model_bh360_support_ticket"/>
            <field name="state">code</field>
            <field name="code">model._check_sla_breach()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
